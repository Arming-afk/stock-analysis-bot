# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Fireworks AI (OpenAI-compatible endpoint) ---
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxx

# --- Webull OpenAPI ---
# Generated at https://www.webull.com/center#openApiManagement (US)
# or https://www.webull.hk/open-api (HK).
# App key / secret only. The system never asks for or stores your account password.
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_ACCOUNT_ID=
# us | hk
WEBULL_REGION=us

# --- Web Push (VAPID) ---
# Generate once:  python tools/gen_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be a real mailto: or https: URL — push services reject an invalid one.
VAPID_CONTACT=mailto:you@example.com

# --- Optional news providers ---
# Leave blank to use the free Google News RSS + yfinance provider.
NEWSAPI_KEY=
